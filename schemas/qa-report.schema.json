{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "status", "automatic_checks", "manual_checks"],
  "properties": {
    "project_id": {"type": "string"},
    "status": {"enum": ["PASS", "FAIL"]},
    "automatic_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "details"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["PASS", "FAIL"]},
          "details": {"type": "string"}
        }
      }
    },
    "manual_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "details"],
        "properties": {
          "id": {"type": "string"},
          "status": {"const": "PENDING"},
          "details": {"type": "string"}
        }
      }
    }
  }
}
